# =========================
# 通用 TTS 配置 (TTS_ 前缀)
# =========================

# 必填：音频生成器类型
# 当前支持: volcengine_ws / minimax_http / edge_tts / voxcpm2_gradio / auto
# auto: 根据 JSON 中每条记录的特征自动判断 provider，支持混合使用
TTS_PROVIDER=auto

# 可选：输出音频格式，支持 mp3 / wav
TTS_ENCODING=mp3

# 可选：并发数
TTS_CONCURRENCY=5

# 必填：输入文件夹路径，扫描其中所有 .json 文件
TTS_INPUT_DIR=input

# 必填：输出根文件夹路径，每个 JSON 在此创建同名子目录
TTS_OUTPUT_DIR=output

# 可选：合并后音频文件名（不含后缀），默认 output
TTS_OUTPUT_FILE_NAME=output

# 可选：重试次数
TTS_RETRY_COUNT=2

# 可选：重试初始延迟 (ms)
TTS_RETRY_DELAY_MS=500

# 可选：重试退避因子
TTS_RETRY_BACKOFF_MS=2

# 可选：重试抖动 (ms)
TTS_RETRY_JITTER_MS=150

# 可选：任务启动间隔 (ms)
TTS_TASK_DELAY_MS=0

# 可选：任务超时 (ms)，0 表示不超时
TTS_TASK_TIMEOUT_MS=0

# 可选：遇到错误是否立即停止 (true / false)
TTS_STOP_ON_ERROR=false

# 可选：FFmpeg 可执行文件路径
# Windows 示例: C:/UserApp/Bin/ffmpeg.exe
# 不填默认使用 PATH 中的 ffmpeg
TTS_FFMPEG_PATH=C:/xxx/ffmpeg.exe

# 可选：Provider 专属配置覆盖
# 格式: key1=val1,key2=val2
# 各 provider 的默认配置和可用字段见:
#   src/audio_create/volcengine-ws.config.ts
#   src/audio_create/minimax-http.config.ts
#   src/audio_create/voxcpm2-gradio.config.ts
# 示例: TTS_PROVIDER_CONFIG=apiKey=xxx,model=seed-tts-2.0-standard
# TTS_PROVIDER_CONFIG=


# =================================
# 火山引擎 TTS 密钥 (VOLC_ 前缀)
# =================================
# 详细配置见 src/audio_create/volcengine-ws.config.ts
# 此处只需配置密钥，其余参数在 config.ts 中修改默认值

# 必填（二选一）：API Key（新版鉴权，推荐）
VOLC_API_KEY=xxxx

# 旧版鉴权（与 VOLC_API_KEY 二选一）
# VOLC_APP_ID=1557479600
# VOLC_ACCESS_TOKEN=


# =================================
# MiniMax TTS 密钥 (MINIMAX_ 前缀)
# =================================
# 详细配置见 src/audio_create/minimax-http.config.ts
# 此处只需配置密钥，其余参数在 config.ts 中修改默认值

# 必填：API Key newapi 中转平台获取key 必须支持 
MINIMAX_API_KEY=xxxx

# 可选：TTS 接口地址 默认使用newapi中转平台获取key 必须支持
MINIMAX_ENDPOINT=https://yunwu.ai/minimax/v1/t2a_v2


# =================================
# VoxCPM2 Gradio TTS (VOXCPM2_ 前缀)
# =================================
# 通过 @gradio/client 直连 VoxCPM2 Gradio 服务
# 详细配置见 src/audio_create/voxcpm2-gradio.config.ts

# 必填：Gradio 服务地址
VOXCPM2_HOST=localhost:8808

# 可选：CFG 引导强度 (1.0-3.0)，默认 2.0
VOXCPM2_CFG_VALUE=2

# 可选：是否归一化
VOXCPM2_DO_NORMALIZE=false

# 可选：是否降噪
VOXCPM2_DENOISE=false

# 可选：DIT 推理步数 (越大质量越好但越慢)，默认 10
VOXCPM2_DIT_STEPS=10